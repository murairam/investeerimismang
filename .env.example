# Copy this file to .env and fill in your values.
# Never commit .env — it is in .gitignore.

OPENAI_API_KEY=sk-...              # GPT-5.4 strategist + risk manager + final gpt-5.4-nano fallback
GEMINI_API_KEY=...                 # Gemini 2.5 Flash catalyst challenger (primary)
OPENROUTER_API_KEY=...             # OpenRouter models: DeepSeek (FullAnalyst), Qwen-235B (Devil), Llama-4 fallback for Gemini
