# Copy this file to .env and fill in your values.
# Never commit .env — it is in .gitignore.

OPENAI_API_KEY=sk-...              # GPT-5.4 strategist + risk manager + gpt-5.4-nano full analyst
GEMINI_API_KEY=...                 # Gemini 2.5 Flash catalyst challenger (free tier)
GROQ_API_KEY=gsk_...               # Groq Llama 3.3 70B fallback when Gemini is down (free tier, optional)
EODHD_API_KEY=...                  # EODHD fallback for tickers yfinance can't fetch
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...
DISCORD_USER_ID=123456789012345678 # Optional: Your Discord user ID for @mentions (right-click username → Copy User ID)
