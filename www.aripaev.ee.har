Id];\\r\\n        console.log(`Destroying slot for ${elementId} [thomas]`);\\r\\n        googletag.destroySlots([slot]);\\r\\n        delete slotMap[elementId];\\r\\n      });\\r\\n    });\\r\\n  }\\r\\n\\r\\n  \\r\\n  fantasyEvents.subscribe(\\\"pageview\\\", (pageViewEvent) => {\\r\\n    console.log(\\\"Got a pageview event:\\\", pageViewEvent, \\\"[thomas]\\\");\\r\\n    const currentPagePath = pageViewEvent.pageInfo?.fullPath;\\r\\n    if (currentPagePath && currentPagePath !== lastPage) {\\r\\n      destroyAllSlots(); \\r\\n      lastPage = currentPagePath;\\r\\n    }\\r\\n  });\\r\\n\\r\\n  \\r\\n  fantasyEvents.subscribeFunction(\\\"render-ad\\\", async (adEvent) => {\\r\\n    console.log(\\\"Got a render-ad event:\\\", adEvent, \\\"[thomas]\\\");\\r\\n\\r\\n    \\r\\n    if (typeof googletag === \\\"undefined\\\" || !googletag.cmd) {\\r\\n      console.warn(\\\"GPT isn’t ready, so we can’t show ads right now. [thomas]\\\");\\r\\n      return;\\r\\n    }\\r\\n\\r\\n    \\r\\n    const currentPagePath = adEvent.pageInfo?.fullPath;\\r\\n    if (currentPagePath && currentPagePath !== lastPage) {\\r\\n      destroyAllSlots();\\r\\n      lastPage = currentPagePath;\\r\\n    }\\r\\n\\r\\n    \\r\\n    if (!adEvent.element.id) {\\r\\n      adEvent.element.id = `fantasy-ad-slot-${adEvent.placement}`;\\r\\n    }\\r\\n    const elementId = adEvent.element.id;\\r\\n\\r\\n    \\r\\n    const adUnitPath = \\\"/22876356962/investeerimismang\\\";\\r\\n\\r\\n    \\r\\n    const containerWidth = adEvent.element.parentElement.parentElement.parentElement.offsetWidth || 0;\\r\\n    let chosenSize = [300, 250]; \\r\\n\\r\\n    if(containerWidth >= 1280){\\r\\nchosenSize = [1280, 250];\\r\\n    }\\r\\n\\r\\n    \\r\\n    \\r\\n    \\r\\n    \\r\\n    \\r\\n    \\r\\n    else if(containerWidth >= 750) {\\r\\n      chosenSize = [750, 250];\\r\\n    }\\r\\n\\r\\n    console.log(\\r\\n      `Container is ${containerWidth}px wide, so we're using size ${chosenSize} [thomas]`\\r\\n    );